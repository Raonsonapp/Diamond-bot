# Telegram
BOT_TOKEN=123456:ABC-your-telegram-bot-token
ADMIN_CHAT_ID=-1000000000000
ADMIN_USER_IDS=111111111,222222222

# Database
DATABASE_PATH=./diamond_bot.db

# Deployment on Render (or any always-on host).
# Leave PUBLIC_URL empty to run locally with polling.
# Set it to your Render service URL to run in webhook mode instead, e.g.:
#   PUBLIC_URL=https://diamond-bot-qakk.onrender.com
PUBLIC_URL=
TELEGRAM_WEBHOOK_PATH=/tg-webhook
# Any random hard-to-guess string; proves incoming requests really came
# from Telegram and not from someone else hitting your public URL.
TELEGRAM_WEBHOOK_SECRET=
# Render sets this automatically at runtime — leave as-is for local runs.
PORT=8080

# Payment provider: "manual" works out of the box (customer sends a receipt
# screenshot, admin confirms in the bot). Switch to "alif" or "dc" only
# after you have signed a real merchant agreement with that bank and
# received real Shop ID / Secret Key / API docs from them.
PAYMENT_PROVIDER=manual

# Your own card that receives customer payments — shown in the bot and (if
# set) used to build a pre-filled ExpressPay pay-by-link ("💳 Пардохт"
# button) so the customer doesn't type the card/amount by hand. Test the
# generated link for real before relying on it.
RECEIVING_CARD_NUMBER=
# http:// on purpose — the https cert doesn't match this hostname.
EXPRESSPAY_BASE_URL=http://pay.expresspay.tj/

ALIF_SHOP_ID=
ALIF_SECRET_KEY=
ALIF_API_BASE_URL=
ALIF_CALLBACK_PATH=/webhooks/alif

# Dushanbe City Bank (dc.tj) merchant/acquiring — contact them directly as
# a registered business to get these.
DC_SHOP_ID=
DC_SECRET_KEY=
DC_API_BASE_URL=
DC_CALLBACK_PATH=/webhooks/dc

WEBHOOK_SERVER_HOST=0.0.0.0
WEBHOOK_SERVER_PORT=8080

# SMS auto payment confirmation: an app on the admin's own phone forwards
# incoming DC Bank "Zachislenie" (deposit) SMS to this URL, and matching
# pending orders get confirmed automatically without a button tap.
# https://diamond-bot-qakk.onrender.com/sms-webhook?secret=<SMS_WEBHOOK_SECRET>
# Leave the secret empty to disable this endpoint entirely.
SMS_WEBHOOK_PATH=/sms-webhook
SMS_WEBHOOK_SECRET=
SMS_MATCH_WINDOW_MINUTES=60

# Diamond delivery provider: "manual" works out of the box (admin tops up
# the player by hand via the official app/site, then taps "Delivered" in
# the bot). "fazercards" calls the real FazerCards reseller API once your
# products are mapped to real category/offer IDs — run /fzr_categories,
# /fzr_offers <category_id> and /mapproduct <product_id> <category_id>
# <offer_id> in the bot first. "auto" is a generic scaffold for any other
# supplier's API (see bot/services/delivery.py).
DELIVERY_PROVIDER=manual

# FazerCards (api.fzr.cards) reseller API key. Keep this out of git —
# it's real money. Only goes in Render's environment variables / your
# local .env, never committed.
FAZERCARDS_API_KEY=
FAZERCARDS_API_BASE_URL=https://api.fzr.cards

SUPPLIER_API_BASE_URL=
SUPPLIER_API_KEY=
